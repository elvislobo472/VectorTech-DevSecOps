# VectorTech Docker Environment Configuration (Example)

# ==========================================
# PostgreSQL Configuration
# ==========================================
POSTGRES_DB=vectortech
POSTGRES_USER=vector_user
POSTGRES_PASSWORD=lobo
POSTGRES_PORT=5432

# ==========================================
# Redis Configuration
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ==========================================
# Backend Spring Boot Configuration
# ==========================================
BACKEND_PORT=8080
DB_HOST=db
DB_PORT=5432
DB_USER=vector_user
DB_PASSWORD=lobo

# JWT Secret (Base64 encoded - REQUIRED)
APP_JWT_SECRET=CHANGE_ME
APP_JWT_EXPIRATION_MS=86400000

# CORS allowed origins (comma-separated)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ==========================================
# Frontend Next.js Configuration
# ==========================================
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
